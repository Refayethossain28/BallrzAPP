{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "firestore.indexes.json",
      ".git/**",
      ".claude/**",
      ".firebase/**",
      "**/node_modules/**",
      "functions/**",
      "ios-app/**",
      "react-native/**",
      "scripts/**",
      "test/**",
      "contracts/**",
      "artifacts/**",
      "cache/**",
      "hardhat.config.js",
      "package.json",
      "package-lock.json",
      "*.sol",
      "*.log",
      ".env*",
      ".firebaserc",
      ".gitignore"
    ],
    "rewrites": [
      { "source": "/BallrzAPP/apexvip-client.html", "destination": "/apexvip-client.html" },
      { "source": "/BallrzAPP/apexvip-driver.html", "destination": "/apexvip-driver.html" },
      { "source": "/BallrzAPP/apexvip-admin.html",  "destination": "/apexvip-admin.html" },
      { "source": "/BallrzAPP/**",                  "destination": "/index.html" },
      { "source": "/",                              "destination": "/index.html" }
    ]
  }
}
