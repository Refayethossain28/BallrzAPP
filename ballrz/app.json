{
  "expo": {
    "name": "Ballrz",
    "slug": "ballrz",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ballrz",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#000000",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ballrz.app"
    },
    "android": {
      "package": "com.ballrz.app",
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": false,
          "supportsPictureInPicture": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ballrz needs access to your library so you can post your highlights."
        }
      ]
    ]
  }
}
