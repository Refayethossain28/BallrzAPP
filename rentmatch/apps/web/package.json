{
  "name": "@rentmatch/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "RentMatch web PWA (renter + landlord client).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:emulators": "cd ../.. && npm --prefix functions run build && npx --yes firebase-tools emulators:exec --project demo-rentmatch --only auth,firestore,functions,storage \"cd apps/web && VITE_USE_EMULATORS=1 playwright test\""
  },
  "dependencies": {
    "@rentmatch/shared": "*",
    "@stripe/react-stripe-js": "^2.7.0",
    "@stripe/stripe-js": "^4.1.0",
    "firebase": "^10.12.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "@tanstack/react-query": "^5.40.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-pwa": "^0.20.0"
  }
}
