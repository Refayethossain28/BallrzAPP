rules_version = '2';

// RentMatch Firestore security rules.
//
// Core principle: money, deal-stage and contract fields are written ONLY by
// Cloud Functions (privileged Admin SDK, which bypasses these rules). Clients
// may create an enquiry and post messages, but may never mutate a deal's stage,
// signatures, payment or contract — those flow exclusively through callable
// Functions that enforce the state machine and compliance gates.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function isParticipant(deal) {
      return uid() == deal.renterId || uid() == deal.landlordId;
    }

    // Users can read/write only their own profile.
    match /users/{userId} {
      allow read, write: if isSignedIn() && uid() == userId;
    }

    // Properties + their compliance docs are owned by the landlord.
    match /properties/{propertyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.landlordId == uid();
      allow update, delete: if isSignedIn() && resource.data.landlordId == uid();

      match /complianceDocs/{docId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() &&
          get(/databases/$(database)/documents/properties/$(propertyId)).data.landlordId == uid();
      }
    }

    // Live listings are publicly readable; only the owning landlord edits them —
    // but `status` is server-authoritative: it changes only via the
    // `publishListing` Cloud Function (Admin SDK), never directly from a client.
    match /listings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.landlordId == uid()
        && request.resource.data.status == 'draft';
      allow update: if isSignedIn() && resource.data.landlordId == uid()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'landlordId']);
      allow delete: if isSignedIn() && resource.data.landlordId == uid();
    }

    // Deals: a renter may open one; both participants may read it.
    match /deals/{dealId} {
      function changedKeys() {
        return request.resource.data.diff(resource.data).affectedKeys();
      }
      allow read: if isSignedIn() && isParticipant(resource.data);
      allow create: if isSignedIn() && request.resource.data.renterId == uid();
      // M2: participants may update only the messaging/viewing/agreement fields,
      // and stage may never be driven past `agreed` from the client. Signatures,
      // payment, contract and stage→contract/signing/completed stay locked to
      // Cloud Functions (M3+).
      allow update: if isSignedIn() && isParticipant(resource.data)
        && changedKeys().hasOnly(['stage', 'viewing', 'agreed', 'updatedAt'])
        && request.resource.data.stage in ['enquiry', 'viewing', 'agreed', 'cancelled'];
      allow delete: if false;

      match /messages/{messageId} {
        // M2: either participant may post in their own deal (this includes the
        // client-generated "system" notes for viewings/agreement). M3 moves
        // system messages behind Cloud Functions so they can't be forged.
        allow read: if isSignedIn() &&
          isParticipant(get(/databases/$(database)/documents/deals/$(dealId)).data);
        allow create: if isSignedIn() &&
          isParticipant(get(/databases/$(database)/documents/deals/$(dealId)).data);
        allow update, delete: if false;
      }

      // Audit trail is append-only via Functions; clients read only.
      match /events/{eventId} {
        allow read: if isSignedIn() &&
          isParticipant(get(/databases/$(database)/documents/deals/$(dealId)).data);
        allow write: if false;
      }
    }

    // Viewings: participants read; writes go through Functions.
    match /viewings/{viewingId} {
      allow read: if isSignedIn() && isParticipant(resource.data);
      allow write: if false;
    }

    // Contracts + payments are entirely Function-managed and read-only to clients.
    match /contracts/{contractId} {
      allow read: if isSignedIn() && isParticipant(resource.data);
      allow write: if false;
    }
    match /payments/{paymentId} {
      allow read: if isSignedIn() && uid() == resource.data.landlordId;
      allow write: if false;
    }

    // Tenancies are the landlord's own rent bookkeeping (not a server-
    // authoritative money flow like deals), so the owning landlord has full
    // CRUD over their tenancies and the payments recorded against them.
    match /tenancies/{tenancyId} {
      allow read, update, delete: if isSignedIn() && resource.data.landlordId == uid();
      allow create: if isSignedIn() && request.resource.data.landlordId == uid();

      match /payments/{paymentId} {
        allow read, write: if isSignedIn() &&
          get(/databases/$(database)/documents/tenancies/$(tenancyId)).data.landlordId == uid();
      }
    }
  }
}
