{
  "name": "@rentmatch/functions",
  "version": "0.0.0",
  "private": true,
  "description": "Cloud Functions: server-authoritative deal transitions, Stripe £100 fee, e-sign webhooks, compliance gating.",
  "main": "lib/index.js",
  "engines": { "node": "22" },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node22 --outfile=lib/index.js --external:firebase-functions --external:firebase-admin --external:stripe",
    "typecheck": "tsc --noEmit",
    "serve": "npm run build && firebase emulators:start --only functions"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "stripe": "^16.0.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0"
  }
}
