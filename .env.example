# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your wallet private key (the account that will deploy the contract and own it)
PRIVATE_KEY=0x...

# Infura project ID — get one free at https://infura.io
INFURA_API_KEY=your_infura_project_id

# Etherscan API key — used to verify the contract source code on Etherscan
# Get one free at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key

# Set to "true" to print gas cost estimates during tests
REPORT_GAS=false

# Deployed contract address (filled in after deployment)
APEX_CONTRACT_ADDRESS=
