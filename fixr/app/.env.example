# Copy to .env (or export these). The app runs fully in DEMO MODE with all of
# these blank; set them to switch on real services.

# Real AI intake (claude-opus-4-8 structured output). Blank -> heuristic parser.
ANTHROPIC_API_KEY=

# Real payment capture + Connect driver settlement. Blank -> mock split.
# Use a test-mode key (sk_test_...) while developing.
STRIPE_SECRET_KEY=

# Real flight tracking via AviationStack. Blank -> deterministic mock.
FLIGHT_API_KEY=

# Database. Blank -> SQLite file (zero-config dev/demo).
# Set a Postgres URL for multi-instance scale, e.g.:
# DATABASE_URL=postgresql://user:pass@host:5432/fixr
DATABASE_URL=

# Optional
PORT=3000
# FIXR_DB=/absolute/path/to/fixr.db   # SQLite file location

# Real client SMS (driver en route, trip complete, concierge fee). Blank -> the
# messages are composed and shown in the console's notifications feed instead.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Lock the operator console + operator APIs behind a shared key. Blank -> open
# demo mode. Driver links and the passenger app are unaffected.
OPERATOR_KEY=
