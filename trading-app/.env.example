# Alpha Vantage API Key - Free at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=demo

# NewsAPI Key - Free at https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here

# Optional: Finnhub API Key for additional market data - Free at https://finnhub.io
FINNHUB_API_KEY=your_finnhub_api_key_here

# Anthropic API Key - powers the AI Analyst (Claude). Get one at https://console.anthropic.com
# If unset, the AI Analyst falls back to a deterministic heuristic.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
