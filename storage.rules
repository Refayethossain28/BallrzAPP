rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Drivers can upload/read their own documents only
    match /driver-docs/{driverId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == driverId
                         && request.resource.size < 10 * 1024 * 1024;
    }
    // Admins can read all driver documents (checked via Firestore custom claims)
    match /driver-docs/{allPaths=**} {
      allow read: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
