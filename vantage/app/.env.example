# Copy to .env (or export these) to switch from demo mode to real services.

# Real AI intake (claude-opus-4-8 structured output). Without it, a deterministic
# heuristic parser is used so the app still runs end-to-end.
ANTHROPIC_API_KEY=

# Real payment capture via Stripe. Without it, captures are mocked (the lifecycle
# still completes). Use a test-mode key (sk_test_...) while developing.
STRIPE_SECRET_KEY=

# Optional
PORT=3000
# VANTAGE_DB=/absolute/path/to/vantage.db
