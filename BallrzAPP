// SettingsView.swift
struct SettingsView: View {
    @EnvironmentObject private var lang: LanguageManager
    @Binding var isLoggedIn: Bool
    @State private var showLogoutConfirm = false

    var body: some View {
        Form {
            Section(lang.localized("settings.language.section")) {
                ForEach(LanguageManager.supported) { language in
                    Button {
                        lang.selectedLanguage = language.id
                    } label: {
                        HStack {
                            Text(lang.localized(language.nameKey))
                                .foregroundStyle(.primary)
                            Spacer()
                            if lang.selectedLanguage == language.id {
                                Image(systemName: "checkmark")
                                    .foregroundStyle(.accent)
                            }
                        }
                    }
                }
            }

            Section(lang.localized("settings.account.section")) {
                Button(lang.localized("settings.button.logout"), role: .destructive) {
                    showLogoutConfirm = true
                }
            }
        }
        .navigationTitle(lang.localized("settings.navigation.title"))
        .environment(\.layoutDirection, lang.currentLanguage.isRTL ? .rightToLeft : .leftToRight)
        .alert(lang.localized("settings.button.logout"), isPresented: $showLogoutConfirm) {
            Button(lang.localized("alert.button.cancel"), role: .cancel) {}
            Button(lang.localized("alert.button.confirm"), role: .destructive) {
                try? Auth.auth().signOut()
                isLoggedIn = false
            }
        } message: {
            Text(lang.localized("alert.logout.confirm"))
        }
    }
}

// LanguagePickerView.swift — compact inline picker used on the Login screen
struct LanguagePickerView: View {
    @EnvironmentObject private var lang: LanguageManager

    var body: some View {
        ScrollView(.horizontal, showsIndicators: false) {
            HStack(spacing: 8) {
                ForEach(LanguageManager.supported) { language in
                    Button {
                        lang.selectedLanguage = language.id
                    } label: {
                        Text(language.id.uppercased())
                            .font(.caption.weight(.semibold))
                            .padding(.horizontal, 10)
                            .padding(.vertical, 6)
                            .background(lang.selectedLanguage == language.id
                                ? Color.accentColor : Color.secondary.opacity(0.2))
                            .foregroundStyle(lang.selectedLanguage == language.id
                                ? Color.white : Color.primary)
                            .clipShape(Capsule())
                    }
                }
            }
            .padding(.horizontal)
        }
    }
}

