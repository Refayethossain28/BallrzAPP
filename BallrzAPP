// LanguageManager.swift
import Foundation
import Combine

final class LanguageManager: ObservableObject {
    static let shared = LanguageManager()

    struct Language: Identifiable, Hashable {
        let id: String        // BCP-47 code, e.g. "en", "es"
        let nameKey: String   // Localizable.strings key for the language's own name
        let isRTL: Bool

        init(_ id: String, nameKey: String, isRTL: Bool = false) {
            self.id = id
            self.nameKey = nameKey
            self.isRTL = isRTL
        }
    }

    static let supported: [Language] = [
        Language("en", nameKey: "language.en"),
        Language("es", nameKey: "language.es"),
        Language("fr", nameKey: "language.fr"),
        Language("ar", nameKey: "language.ar", isRTL: true),
        Language("pt", nameKey: "language.pt"),
    ]

    @Published var selectedLanguage: String {
        didSet {
            UserDefaults.standard.set(selectedLanguage, forKey: "appLanguage")
        }
    }

    private init() {
        selectedLanguage = UserDefaults.standard.string(forKey: "appLanguage")
            ?? Locale.current.language.languageCode?.identifier
            ?? "en"
    }

    var currentLanguage: Language {
        LanguageManager.supported.first { $0.id == selectedLanguage }
            ?? LanguageManager.supported[0]
    }

    // Resolve a localized string for the currently selected language bundle.
    func localized(_ key: String) -> String {
        guard let path = Bundle.main.path(forResource: selectedLanguage, ofType: "lproj"),
              let bundle = Bundle(path: path) else {
            return NSLocalizedString(key, comment: "")
        }
        return bundle.localizedString(forKey: key, value: nil, table: nil)
    }
}

// ContentView.swift
struct ContentView: View {
    @EnvironmentObject private var lang: LanguageManager
    @State private var isLoggedIn = false

    var body: some View {
        if isLoggedIn {
            MainFeedView(isLoggedIn: $isLoggedIn)
        } else {
            LoginView(isLoggedIn: $isLoggedIn)
        }
    }
}

// LoginView.swift
struct LoginView: View {
    @EnvironmentObject private var lang: LanguageManager
    @Binding var isLoggedIn: Bool
    @State private var email = ""
    @State private var password = ""
    @State private var errorMessage: String?
    @State private var showError = false

    var body: some View {
        VStack(spacing: 16) {
            Spacer()

            Text("Ballrz")
                .font(.largeTitle.bold())

            TextField(lang.localized("login.email.placeholder"), text: $email)
                .textFieldStyle(.roundedBorder)
                .keyboardType(.emailAddress)
                .autocapitalization(.none)
                .padding(.horizontal)

            SecureField(lang.localized("login.password.placeholder"), text: $password)
                .textFieldStyle(.roundedBorder)
                .padding(.horizontal)

            Button(lang.localized("login.button.login")) {
                Auth.auth().signIn(withEmail: email, password: password) { result, error in
                    if result != nil {
                        isLoggedIn = true
                    } else {
                        errorMessage = error?.localizedDescription
                            ?? lang.localized("alert.login.failed")
                        showError = true
                    }
                }
            }
            .buttonStyle(.borderedProminent)

            Button(lang.localized("login.button.register")) {
                Auth.auth().createUser(withEmail: email, password: password) { result, error in
                    if result != nil {
                        isLoggedIn = true
                    } else {
                        errorMessage = error?.localizedDescription
                            ?? lang.localized("alert.register.failed")
                        showError = true
                    }
                }
            }
            .buttonStyle(.bordered)

            Spacer()

            LanguagePickerView()
                .padding(.bottom)
        }
        .padding()
        .environment(\.layoutDirection, lang.currentLanguage.isRTL ? .rightToLeft : .leftToRight)
        .alert(lang.localized("alert.error.title"), isPresented: $showError) {
            Button(lang.localized("alert.button.confirm"), role: .cancel) {}
        } message: {
            Text(errorMessage ?? "")
        }
    }
}

