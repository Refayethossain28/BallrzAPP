# Optional non-secret config for the getHotelRates function.
# Copy to `.env` (gitignored) to override. Secrets are NOT set here — use
# `firebase functions:secrets:set AMADEUS_CLIENT_ID` / `AMADEUS_CLIENT_SECRET`.

# Amadeus environment. Test (default) is free with limited inventory.
# Switch to production (paid/contracted) when ready:
# AMADEUS_HOST=https://api.amadeus.com
AMADEUS_HOST=https://test.api.amadeus.com
