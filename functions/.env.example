# Optional non-secret config for the getHotelRates function.
# Copy to `.env` (gitignored) to override. Secrets are NOT set here — use
# `firebase functions:secrets:set AMADEUS_CLIENT_ID` / `AMADEUS_CLIENT_SECRET`.

# Amadeus environment. Test (default) is free with limited inventory.
# Switch to production (paid/contracted) when ready:
# AMADEUS_HOST=https://api.amadeus.com
AMADEUS_HOST=https://test.api.amadeus.com

# Square. Sandbox by default; set production for live charges.
# SQUARE_ENV=production
SQUARE_ENV=sandbox
SQUARE_LOCATION_ID=

# Booking notifications (onBookingWrite). Secrets set via functions:secrets:set.
NOTIFY_FROM_EMAIL=concierge@apexvip.com
NOTIFY_FROM_NAME=ApexVIP
TWILIO_FROM_NUMBER=

# Lingua language app (linguaAI) + ApexAI concierge (parseBookingIntent) both use
# Anthropic. The key is a SECRET — set it with
# `firebase functions:secrets:set ANTHROPIC_API_KEY` (do NOT put it here).
# Optionally override the models (both default to claude-opus-4-8):
# LINGUA_MODEL=claude-opus-4-8
# APEXAI_MODEL=claude-opus-4-8

# Consolidation stubs (functions:secrets:set …). All optional — the functions
# degrade gracefully until these are provisioned:
#   FLIGHT_API_KEY            — AviationStack access key for checkFlightStatus
#   APPLE_PAY_MERCHANT_CERT   — Apple Pay merchant identity cert (PEM)
#   APPLE_PAY_MERCHANT_KEY    — Apple Pay merchant identity key (PEM)
